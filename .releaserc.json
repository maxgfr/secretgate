{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md",
        "changelogTitle": "# Changelog\n\nAll notable changes to this project are documented here, generated automatically from the Conventional Commits by semantic-release."
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node scripts/sync-version.mjs ${nextRelease.version} && pnpm run build"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "package.json",
          "src/version.ts",
          "skills/secretgate/SKILL.md",
          "CHANGELOG.md",
          "scripts/secretgate.mjs",
          "scripts/secretgate-opencode.mjs",
          "skills/secretgate/scripts/secretgate.mjs"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [{ "path": "scripts/secretgate.mjs", "label": "secretgate.mjs (install-free bundle)" }]
      }
    ]
  ]
}
